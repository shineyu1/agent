generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ListingState {
  DRAFT
  LISTED
  UNLISTED
  ARCHIVED
}

enum CredentialMode {
  HOSTED
  RELAY
}

enum FulfillmentStatus {
  PENDING
  SUCCEEDED
  FAILED
}

model Provider {
  id                 String         @id @default(cuid())
  name               String
  slug               String         @unique
  ownerWalletAddress String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  services           Service[]
  payoutWallets      PayoutWallet[]

  @@index([ownerWalletAddress])
}

model Service {
  id                 String              @id @default(cuid())
  providerId         String
  name               String
  slug               String              @unique
  description        String
  category           String
  tags               String[]
  listingState       ListingState        @default(DRAFT)
  credentialMode     CredentialMode
  sourceKind         String
  upstreamUrl        String?
  httpMethod         String?
  specUrl            String?
  operationId        String?
  inputSchema        Json
  outputSchema       Json
  priceAmount        Decimal             @db.Decimal(18, 6)
  priceCurrency      String              @default("USDT")
  successRate        Float               @default(0)
  avgLatencyMs       Int                 @default(0)
  recentPaidCallCount Int                @default(0)
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  provider           Provider            @relation(fields: [providerId], references: [id], onDelete: Cascade)
  payoutWallet       PayoutWallet?
  upstreamCredential UpstreamCredential?
  relayConfiguration RelayConfiguration?
  paymentRecords     PaymentRecord[]
  paymentAttempts    PaymentAttempt[]
  paymentProofClaims PaymentProofClaim[]
  fulfillmentRecords FulfillmentRecord[]
}

model PaymentProofClaim {
  id                 String    @id @default(cuid())
  serviceId          String
  proofDigest        String
  payerAddress       String?
  verificationSource String?
  quoteVersion       Int?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  service            Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, proofDigest])
}

model PaymentAttempt {
  id                 String    @id @default(cuid())
  serviceId          String
  payerAddress       String?
  status             String
  invalidReason      String?
  verificationSource String?
  proofDigest        String?
  quoteVersion       Int?
  receiptJson        Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  service            Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model PayoutWallet {
  id             String    @id @default(cuid())
  providerId     String
  serviceId      String?   @unique
  network        String
  address        String
  feeBps         Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  provider       Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  service        Service?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)
}

model UpstreamCredential {
  id             String    @id @default(cuid())
  serviceId      String    @unique
  authType       String
  secretCipher   String
  keyHint        String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  service        Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model RelayConfiguration {
  id             String    @id @default(cuid())
  serviceId      String    @unique
  relayUrl       String
  signingSecret  String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  service        Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model PaymentRecord {
  id               String      @id @default(cuid())
  serviceId        String
  amount           Decimal     @db.Decimal(18, 6)
  assetAddress     String?
  payerAddress     String?
  transactionHash  String?     @unique
  status           String
  verificationSource String?
  proofDigest      String?
  quoteVersion     Int?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  service          Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  fulfillment      FulfillmentRecord?
}

model FulfillmentRecord {
  id                String             @id @default(cuid())
  serviceId         String
  paymentRecordId   String             @unique
  status            FulfillmentStatus  @default(PENDING)
  responseCode      Int?
  latencyMs         Int?
  failureReason     String?
  receiptJson       Json?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  service           Service            @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  paymentRecord     PaymentRecord      @relation(fields: [paymentRecordId], references: [id], onDelete: Cascade)
}
